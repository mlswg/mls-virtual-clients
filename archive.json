    {
      "number": 11,
      "id": "PR_kwDOKsv6Xc7VTOo_",
      "title": "flesh out emulation client onboarding procedure",
      "url": "https://github.com/mlswg/mls-virtual-clients/pull/11",
      "state": "MERGED",
      "author": "kkohbrok",
